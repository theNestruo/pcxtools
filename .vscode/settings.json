// Place your settings in this file to overwrite default and user settings.
{
	"files.associations": {
		"*.makefile": "makefile"
	},

    // Code style preferences
	"editor.insertSpaces": false,
	"editor.tabSize": 4,
	"editor.rulers": [
		80, 120
	],

	"files.exclude": {
		"**/*.o": { "when": "$(basename).c" },
		"~tmppre.?": true,
	},

	// No AI
	"chat.disableAIFeatures": true,
}
